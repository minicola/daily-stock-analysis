# ignore Claude workspace artifacts, but keep shared repo skills versioned
.claude/*
!.claude/skills/
!.claude/skills/**
# (must come after the !.claude/skills/** unignore, otherwise the
# global **/.DS_Store rule cannot reach files inside skills/)
.claude/skills/**/.DS_Store

# Serena MCP 本地配置
.serena/

# ignore static files
static/
/apps/dsa-desktop/dist/
/apps/dsa-desktop/node_modules/
/apps/dsa-desktop/package-lock.json
/apps/dsa-web/node_modules/

# Root-level npm artifacts from `npm install @anthropic-ai/claude-code`
# (Claude Code lives outside this project's source tree.)
/node_modules/
/package.json
/package-lock.json

# Local debug / personal seed scripts (not project source)
# - check_holdings.py / fetch_market_data.py: ad-hoc debug runners
# - scripts/seed_my_portfolio.py: contains private trade data
/check_holdings.py
/fetch_market_data.py
/scripts/seed_my_portfolio.py

# git worktrees (isolated dev workspaces)
.worktrees/
